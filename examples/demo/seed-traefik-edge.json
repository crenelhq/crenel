{
  "_comment": "DEMO Traefik edge seed — FAKE hostnames only. One existing route + crenel manages the rest between its sentinels.",
  "http": {
    "routers": {
      "auth": {
        "rule": "Host(`auth.example.com`)",
        "service": "auth-svc",
        "entryPoints": ["websecure"]
      }
    },
    "services": {
